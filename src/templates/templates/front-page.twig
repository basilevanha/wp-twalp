{% extends 'layouts/base.twig' %}

{% block content %}
	<div
		x-data="{
			x: 50, y: 50,
			tx: 50, ty: 50,
			t: 0,
			blob: '',
			init() {
				this.loop()
			},
			move(e) {
				const rect = this.$el.getBoundingClientRect()
				this.tx = ((e.clientX - rect.left) / rect.width) * 100
				this.ty = ((e.clientY - rect.top) / rect.height) * 100
			},
			loop() {
				this.x += (this.tx - this.x) * 0.04
				this.y += (this.ty - this.y) * 0.04
				this.t += 0.008
				const s = Math.sin, t = this.t
				const r1 = 40 + 10 * s(t * 1.1)
				const r2 = 50 + 10 * s(t * 1.4 + 1)
				const r3 = 45 + 10 * s(t * 0.9 + 2)
				const r4 = 50 + 10 * s(t * 1.2 + 3)
				const r5 = 55 + 10 * s(t * 1.0 + 4)
				const r6 = 45 + 10 * s(t * 1.3 + 5)
				const r7 = 50 + 10 * s(t * 0.8 + 6)
				const r8 = 40 + 10 * s(t * 1.1 + 7)
				const sc = 1 + 0.04 * s(t * 0.7)
				this.blob = `border-radius:${r1}% ${100-r1}% ${r2}% ${100-r2}% / ${r3}% ${r4}% ${100-r4}% ${100-r3}%;transform:translate(-50%,-50%) scale(${sc})`
				requestAnimationFrame(() => this.loop())
			}
		}"
		@mousemove.throttle.16ms="move($event)"
		class="relative flex flex-1 flex-col items-center justify-center overflow-hidden bg-secondary"
	>
		<div class="pointer-events-none absolute h-[500px] w-[500px] bg-linear-to-br from-primary/30 to-primary/10 blur-xl" :style="`left:${x}%;top:${y}%;${blob}`"></div>

		<div class="relative z-10 mx-auto max-w-3xl px-6 py-24 text-center">
			<h1 class="text-5xl font-extrabold tracking-tight text-foreground sm:text-6xl">
				{{ post.title }}
			</h1>

			{% if post.content %}
				<div class="mt-6 text-lg leading-relaxed text-muted-foreground">
					{{ post.content|raw }}
				</div>
			{% endif %}

			<div class="mt-16 grid gap-8 sm:grid-cols-3">
				<div class="rounded-2xl bg-card/70 p-6 shadow-sm backdrop-blur-sm ring-1 ring-border">
					<p class="text-3xl font-bold text-primary">Timber</p>
					<p class="mt-2 text-sm text-muted-foreground">Twig templates</p>
				</div>
				<div class="rounded-2xl bg-card/70 p-6 shadow-sm backdrop-blur-sm ring-1 ring-border">
					<p class="text-3xl font-bold text-primary">Tailwind</p>
					<p class="mt-2 text-sm text-muted-foreground">Utility-first CSS</p>
				</div>
				<div class="rounded-2xl bg-card/70 p-6 shadow-sm backdrop-blur-sm ring-1 ring-border">
					<p class="text-3xl font-bold text-primary">Alpine</p>
					<p class="mt-2 text-sm text-muted-foreground">Reactive interactions</p>
				</div>
			</div>

			<p class="mt-12 text-sm text-muted-foreground">{{ site.name }} &middot; {{ "now"|date("Y") }}</p>
		</div>
	</div>
{% endblock %}
