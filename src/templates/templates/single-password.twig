{% extends 'layouts/base.twig' %}

{% block content %}
	<form action="{{ site.link }}/wp-login.php?action=postpass" method="post">
		<label for="pwbox-{{ post.id }}">{{ __('Password:', 'starter-theme') }}</label>
		<input name="post_password" id="pwbox-{{ post.id }}" type="password" placeholder="{{ __('Password', 'starter-theme') }}" size="20" maxlength="20" />
		<input type="submit" name="Submit" value="{{ __('Submit', 'starter-theme') }}" />
	</form>
{% endblock %}
