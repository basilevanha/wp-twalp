{% extends 'partials/tease.twig' %}

{% block content %}
    <h2 class="h2"><a href="{{ post.link }}">{{ post.title }}</a></h2>
    <p>
        {{
            post.excerpt({
                words: 5,
                read_more: __('Keep reading', 'starter-theme')
            })|raw
        }}
    </p>
    {% if post.thumbnail.src %}
        <img src="{{ post.thumbnail.src }}" alt="{{ post.thumbnail.alt|default(post.title) }}" />
    {% endif %}
{% endblock %}
