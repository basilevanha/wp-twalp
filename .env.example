# ──────────────────────────────────────────────
# Project
# ──────────────────────────────────────────────
PROJECT_NAME=starter-theme
THEME_DIR=./public/wp-content/themes/starter-theme
# For DevKinsta:  THEME_DIR=~/DevKinsta/public/my-site/wp-content/themes/my-theme
# For existing WP: THEME_DIR=/path/to/wordpress/wp-content/themes/my-theme

# ──────────────────────────────────────────────
# WordPress
# ──────────────────────────────────────────────
WP_HOME=http://localhost:8080
WP_SITEURL=http://localhost:8080

# ──────────────────────────────────────────────
# Database (Docker only)
# ──────────────────────────────────────────────
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=wordpress
DB_HOST=db

# ──────────────────────────────────────────────
# Vendor path (Composer autoload)
# ──────────────────────────────────────────────
# Docker:    VENDOR_PATH=/var/www/vendor  (volume mapped in docker-compose.yml)
# DevKinsta: VENDOR_PATH=                (leave empty, uses local path)
# Local WP:  VENDOR_PATH=                (leave empty, uses local path)
VENDOR_PATH=/var/www/vendor

# ──────────────────────────────────────────────
# Vite dev server
# ──────────────────────────────────────────────
VITE_DEV_SERVER=http://localhost:5173
