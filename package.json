{
  "name": "wp-boilerplate",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node bin/dev.js",
    "build": "node bin/sync.js --production && vite build",
    "sync": "node bin/sync.js",
    "setup": "bash bin/setup.sh",
    "stop": "docker compose -f docker/docker-compose.yml --env-file .env down",
    "reset": "docker compose -f docker/docker-compose.yml --env-file .env down -v 2>/dev/null; rm -rf public .env .setup-state node_modules vendor && echo '✔ Project reset. Run npm run setup to start fresh.'"
  },
  "devDependencies": {
    "chokidar": "^4.0.0",
    "dotenv": "^16.4.0",
    "sass": "^1.80.0",
    "vite": "^6.0.0",
    "vite-plugin-live-reload": "^3.0.0"
  }
}
